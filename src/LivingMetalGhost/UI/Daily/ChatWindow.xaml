<Window x:Class="LivingMetalGhost.UI.Views.ChatWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="LivingMetalGhost Chat"
        Width="486"
        SizeToContent="Height"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        ShowActivated="False">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
        <LinearGradientBrush x:Key="InputFillBrush" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#FFF8F0" Offset="0" />
            <GradientStop Color="#F6EADD" Offset="1" />
        </LinearGradientBrush>
    </Window.Resources>

    <Grid Background="Transparent" Margin="8">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- ChatWindow.xaml.cs keeps these names for mode labels, but the default chat input uses compact bubble UI. -->
        <StackPanel Grid.Row="0" Visibility="Collapsed">
            <TextBlock x:Name="TitleLabel" />
            <TextBlock x:Name="ProviderLabel" />
        </StackPanel>

        <Border Grid.Row="0"
                MaxWidth="390"
                Margin="54,0,12,8"
                Padding="14,9"
                HorizontalAlignment="Right"
                Background="#E8D7F6"
                BorderBrush="#C4A1DF"
                BorderThickness="1"
                CornerRadius="16,16,4,16"
                Visibility="{Binding IsUserMessagePending, Converter={StaticResource BooleanToVisibilityConverter}}">
            <TextBlock Text="{Binding PendingUserMessageText}"
                       TextWrapping="Wrap"
                       Foreground="#34213F"
                       FontSize="13" />
        </Border>

        <Border x:Name="InputPanel"
                Grid.Row="1"
                Padding="10,10,14,10"
                Background="{StaticResource InputFillBrush}"
                BorderBrush="#E4D4C6"
                BorderThickness="1"
                CornerRadius="22"
                MouseLeftButtonDown="InputPanel_OnMouseLeftButtonDown">
            <Border.Effect>
                <DropShadowEffect BlurRadius="20"
                                  ShadowDepth="4"
                                  Direction="300"
                                  Opacity="0.18"
                                  Color="#24182B" />
            </Border.Effect>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <Border x:Name="DragGrip"
                        Grid.Column="0"
                        Width="34"
                        Margin="0,0,8,0"
                        CornerRadius="14"
                        Background="#18A579D8"
                        Cursor="SizeAll"
                        MouseLeftButtonDown="InputPanel_OnMouseLeftButtonDown"
                        ToolTip="드래그해서 대화 입력창 위치를 옮깁니다.">
                    <TextBlock HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               FontFamily="Consolas"
                               FontSize="16"
                               Foreground="#8C7A9F"
                               Text="⋮⋮" />
                </Border>

                <TextBox x:Name="PromptTextBox"
                         Grid.Column="1"
                         MinHeight="42"
                         MaxHeight="80"
                         Padding="4,6"
                         AcceptsReturn="True"
                         TextWrapping="Wrap"
                         VerticalScrollBarVisibility="Auto"
                         Background="Transparent"
                         Foreground="#241B2B"
                         BorderThickness="0"
                         PreviewMouseLeftButtonDown="InputPanel_OnMouseLeftButtonDown"
                         PreviewKeyDown="PromptTextBox_OnPreviewKeyDown"
                         Text="{Binding InputText, UpdateSourceTrigger=PropertyChanged}"
                         ToolTip="메시지를 입력하세요. Enter 전송, Shift+Enter 줄바꿈" />

                <Button x:Name="SendButton"
                        Grid.Column="2"
                        Width="46"
                        Height="46"
                        Margin="10,0,0,0"
                        Padding="0"
                        VerticalAlignment="Center"
                        Background="#9B6AD6"
                        Foreground="White"
                        BorderThickness="0"
                        Command="{Binding SendCommand}"
                        Content="➤"
                        FontSize="20"
                        Cursor="Hand"
                        ToolTip="보내기" />
            </Grid>
        </Border>
    </Grid>
</Window>
