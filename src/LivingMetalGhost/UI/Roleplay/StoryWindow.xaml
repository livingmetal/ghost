<Window x:Class="LivingMetalGhost.UI.Views.StoryWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:behaviors="clr-namespace:LivingMetalGhost.UI.Behaviors"
        xmlns:primitives="clr-namespace:System.Windows.Controls.Primitives;assembly=PresentationFramework"
        Title="LivingMetalGhost Roleplay"
        Width="470"
        Height="660"
        MinWidth="420"
        MinHeight="500"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        ShowActivated="False">
    <Grid Background="Transparent">
        <Border x:Name="RootBorder" Margin="8" Padding="16" Background="#F4EFE5" BorderThickness="2" CornerRadius="22">
            <Border.BorderBrush>
                <SolidColorBrush x:Name="BorderAccent" Color="#9B6AD6" />
            </Border.BorderBrush>
            <Border.Effect>
                <DropShadowEffect BlurRadius="20" ShadowDepth="6" Opacity="0.28" Color="#101820" />
            </Border.Effect>

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Grid MouseLeftButtonDown="Header_OnMouseLeftButtonDown" Cursor="SizeAll">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel>
                        <TextBlock x:Name="TitleLabel" FontFamily="Bahnschrift" FontSize="20" FontWeight="SemiBold" Foreground="#3A2E6B" Text="ROLEPLAY CONSOLE" />
                        <TextBlock x:Name="ProviderLabel" Margin="0,2,0,0" FontFamily="Consolas" FontSize="10" Foreground="#7A6BA8" Text="{Binding StoryProviderLabel}" />
                    </StackPanel>
                    <Button Grid.Column="1" Width="30" Height="30" Padding="0" Background="#3A2E6B" Foreground="White" BorderThickness="0" Click="CloseButton_OnClick" Content="×" />
                </Grid>

                <Border Grid.Row="1" Margin="0,14,0,0" CornerRadius="8" Background="#202020" BorderBrush="#343434" BorderThickness="1">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Setter Property="Visibility" Value="Visible" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsStoryInfoPanelVisible}" Value="False">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <StackPanel>
                        <Border Padding="12,8" CornerRadius="8,8,0,0" Background="#3A3834">
                            <TextBlock FontFamily="Georgia" FontSize="13" Foreground="#8A8178" Text="Info" />
                        </Border>
                        <TextBlock Margin="12,10,12,12" FontFamily="Consolas" FontSize="12" Foreground="#D8D3CD" TextWrapping="Wrap" Text="{Binding StoryInfoText}" />
                    </StackPanel>
                </Border>

                <Border Grid.Row="2" Margin="0,14,0,10" Padding="0" CornerRadius="16" Background="#FFFDF8" BorderBrush="#D8D0C3" BorderThickness="1">
                    <ScrollViewer x:Name="ConversationScrollViewer" Padding="14,12" HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
                        <ItemsControl ItemsSource="{Binding StoryMessages}" HorizontalContentAlignment="Stretch">
                            <ItemsControl.ItemContainerStyle>
                                <Style TargetType="ContentPresenter">
                                    <Setter Property="HorizontalAlignment" Value="Stretch" />
                                </Style>
                            </ItemsControl.ItemContainerStyle>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Margin="0,0,0,14" Padding="0,0,0,14" BorderBrush="#E6DED2" BorderThickness="0,0,0,1" HorizontalAlignment="Stretch">
                                        <StackPanel>
                                            <DockPanel Margin="0,0,0,7">
                                                <TextBlock DockPanel.Dock="Left" FontFamily="Consolas" FontSize="11" FontWeight="SemiBold" Foreground="#7A6BA8" Text="{Binding SpeakerName}" />
                                                <TextBlock DockPanel.Dock="Right" HorizontalAlignment="Right" FontFamily="Consolas" FontSize="10" Foreground="#9A90B5" Text="{Binding Timestamp, StringFormat={}{0:HH:mm}}" />
                                            </DockPanel>
                                            <RichTextBox Padding="0" FontFamily="Malgun Gothic" FontSize="14" Foreground="#202A35" Background="Transparent" BorderThickness="0" IsReadOnly="True" IsReadOnlyCaretVisible="False" IsDocumentEnabled="True" HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Disabled" behaviors:InlineMarkup.Text="{Binding DisplayText, Mode=OneWay}" behaviors:InlineMarkup.Roleplay="{Binding IsRoleplay, Mode=OneWay}" ToolTip="드래그해서 선택하거나 Ctrl+C로 복사할 수 있습니다.">
                                                <RichTextBox.Resources>
                                                    <Style TargetType="Paragraph">
                                                        <Setter Property="Margin" Value="0,0,0,8" />
                                                        <Setter Property="LineHeight" Value="22" />
                                                    </Style>
                                                </RichTextBox.Resources>
                                                <RichTextBox.ContextMenu>
                                                    <ContextMenu>
                                                        <MenuItem Command="ApplicationCommands.Copy" Header="복사" />
                                                        <MenuItem Command="ApplicationCommands.SelectAll" Header="전체 선택" />
                                                    </ContextMenu>
                                                </RichTextBox.ContextMenu>
                                            </RichTextBox>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Border>

                <Grid Grid.Row="3">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <Border Grid.Row="0" Grid.ColumnSpan="3" Margin="0,0,0,7" Padding="9,5" CornerRadius="8" Background="#E9E2F5">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding StorySelectedImage}" Value="{x:Null}">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <DockPanel>
                            <Button DockPanel.Dock="Right" Width="22" Height="22" Padding="0" BorderThickness="0" Background="Transparent" Click="RemoveImageButton_OnClick" Content="×" />
                            <TextBlock VerticalAlignment="Center" Foreground="#5D4775" Text="{Binding StorySelectedImage.FileName, StringFormat=이미지: {0}}" />
                        </DockPanel>
                    </Border>
                    <TextBox x:Name="PromptTextBox" Grid.Row="1" MinHeight="64" MaxHeight="120" Padding="12,10" AcceptsReturn="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto" BorderBrush="#B8AEDA" BorderThickness="1" PreviewKeyDown="PromptTextBox_OnPreviewKeyDown" Text="{Binding StoryInputText, UpdateSourceTrigger=PropertyChanged}" ToolTip="평문=대사 · *행동* · (속마음)" />
                    <Button Grid.Row="1" Grid.Column="1" Margin="8,0,0,0" Width="44" Background="#EEE7F7" Foreground="#5D4775" BorderBrush="#B8AEDA" BorderThickness="1" Click="AttachImageButton_OnClick" Content="＋" FontSize="20" ToolTip="이미지 첨부" />
                    <Button x:Name="SendButton" Grid.Row="1" Grid.Column="2" Margin="8,0,0,0" MinWidth="76" Padding="14,8" VerticalAlignment="Stretch" Background="#9B6AD6" Foreground="White" BorderThickness="0" Command="{Binding StorySendCommand}" Content="SEND" />
                </Grid>
            </Grid>
        </Border>

        <primitives:Thumb x:Name="ResizeThumb" Width="20" Height="20" Margin="0,0,10,10" HorizontalAlignment="Right" VerticalAlignment="Bottom" Cursor="SizeNWSE" DragDelta="ResizeThumb_OnDragDelta">
            <primitives:Thumb.Template>
                <ControlTemplate TargetType="primitives:Thumb">
                    <Grid Background="Transparent">
                        <Path Stroke="#8C7A6D" StrokeThickness="1.6" StrokeEndLineCap="Round" Data="M 6,17 L 17,6 M 11,17 L 17,11" />
                    </Grid>
                </ControlTemplate>
            </primitives:Thumb.Template>
        </primitives:Thumb>
    </Grid>
</Window>
