<Window x:Class="LivingMetalGhost.UI.Views.SpeechBubbleWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="LivingMetalGhost Speech"
        Width="444"
        MinHeight="118"
        MaxHeight="520"
        SizeToContent="Height"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        ShowActivated="False">
    <Window.Resources>
        <LinearGradientBrush x:Key="BubbleFillBrush" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#FFFFFC" Offset="0" />
            <GradientStop Color="#FBF5EF" Offset="0.58" />
            <GradientStop Color="#F1E7DD" Offset="1" />
        </LinearGradientBrush>
    </Window.Resources>

    <Grid x:Name="BubbleRoot"
          Background="Transparent"
          Margin="8"
          Opacity="0">
        <Grid.Effect>
            <DropShadowEffect BlurRadius="26"
                              ShadowDepth="7"
                              Direction="300"
                              Opacity="0.24"
                              Color="#2A1A30" />
        </Grid.Effect>

        <Border Margin="2,4,4,8"
                CornerRadius="30"
                Background="#44FFFFFF" />

        <Path HorizontalAlignment="Right"
              VerticalAlignment="Bottom"
              Margin="0,0,34,-14"
              Fill="#1F2A1A30"
              Data="M 3,0 C 14,6 28,13 40,30 C 25,22 12,22 3,0 Z" />
        <Path HorizontalAlignment="Right"
              VerticalAlignment="Bottom"
              Margin="0,0,36,-11"
              Fill="#F1E7DD"
              Stroke="#E8DDD2"
              StrokeThickness="1"
              Data="M 0,0 C 12,5 25,12 36,27 C 23,20 10,20 0,0 Z" />

        <Border x:Name="RootBorder"
                Margin="0,0,0,6"
                Padding="20,17,20,18"
                CornerRadius="28"
                BorderThickness="1.2"
                Background="{StaticResource BubbleFillBrush}">
            <Border.BorderBrush>
                <SolidColorBrush x:Name="BorderAccent" Color="#E8DDD2" />
            </Border.BorderBrush>
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <StackPanel>
                    <TextBlock FontFamily="Bahnschrift"
                               FontSize="13"
                               FontWeight="SemiBold"
                               Foreground="#7C55BA"
                               Text="{Binding CharacterDisplayName}" />
                    <TextBlock Margin="0,1,0,0"
                               FontSize="10"
                               Foreground="#9A8D82"
                               Text="speaking" />
                </StackPanel>

                <ScrollViewer Grid.Row="1"
                              Margin="0,11,0,0"
                              MaxHeight="360"
                              HorizontalScrollBarVisibility="Disabled"
                              VerticalScrollBarVisibility="Auto"
                              CanContentScroll="False">
                    <TextBlock x:Name="BubbleTextBlock"
                               FontFamily="Malgun Gothic"
                               FontSize="15"
                               FontWeight="SemiBold"
                               LineHeight="23"
                               TextWrapping="Wrap"
                               Foreground="#241B2B" />
                </ScrollViewer>
            </Grid>
        </Border>
    </Grid>
</Window>