<Window x:Class="LivingMetalGhost.UI.Views.StoryWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:behaviors="clr-namespace:LivingMetalGhost.UI.Behaviors"
        xmlns:controls="clr-namespace:LivingMetalGhost.UI.Controls"
        Title="LivingMetalGhost Story"
        Width="480"
        Height="760"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        ShowActivated="False">
    <Grid Background="Transparent">
        <Border Margin="8"
                Padding="14"
                Background="#F4EFE5"
                BorderThickness="2"
                CornerRadius="22">
            <Border.BorderBrush>
                <SolidColorBrush Color="#9B6AD6" />
            </Border.BorderBrush>
            <Border.Effect>
                <DropShadowEffect BlurRadius="20"
                                  ShadowDepth="6"
                                  Opacity="0.28"
                                  Color="#101820" />
            </Border.Effect>

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Grid MouseLeftButtonDown="Header_OnMouseLeftButtonDown"
                      Cursor="SizeAll">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel>
                        <TextBlock FontFamily="Bahnschrift"
                                   FontSize="20"
                                   FontWeight="SemiBold"
                                   Foreground="#3A2E6B"
                                   Text="ROLEPLAY" />
                        <TextBlock x:Name="StoryTitleLabel"
                                   Margin="0,2,0,0"
                                   FontFamily="Consolas"
                                   FontSize="10"
                                   Foreground="#7A6BA8"
                                   Text="" />
                    </StackPanel>
                    <Button Grid.Column="1"
                            Width="30"
                            Height="30"
                            Padding="0"
                            Background="#3A2E6B"
                            Foreground="White"
                            BorderThickness="0"
                            Click="CloseButton_OnClick"
                            Content="×"
                            ToolTip="롤플레잉을 끝내고 데스크톱으로 돌아갑니다." />
                </Grid>

                <Border Grid.Row="1"
                        Height="320"
                        Margin="0,12,0,10"
                        CornerRadius="16"
                        Background="#ECE6FB"
                        BorderBrush="#D8CEF2"
                        BorderThickness="1"
                        ClipToBounds="True">
                    <controls:CharacterHost x:Name="StoryCharacterHost"
                                            HorizontalAlignment="Center"
                                            VerticalAlignment="Bottom"
                                            CharacterId="{Binding SelectedCharacterId}"
                                            Mood="{Binding CharacterMood}"
                                            IsSpeaking="{Binding IsCharacterSpeaking}"
                                            SizePresetId="{Binding SelectedCharacterSizePresetId}"
                                            FramingPresetId="{Binding SelectedCharacterFramingPresetId}"
                                            UserScale="{Binding CharacterScale}" />
                </Border>

                <Border Grid.Row="2"
                        Padding="8"
                        CornerRadius="16"
                        Background="#FFFDF8"
                        BorderBrush="#D8D0C3"
                        BorderThickness="1">
                    <ScrollViewer x:Name="ConversationScrollViewer"
                                  VerticalScrollBarVisibility="Auto">
                        <ItemsControl ItemsSource="{Binding Messages}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border MaxWidth="400"
                                            Margin="5,4"
                                            Padding="11,9"
                                            HorizontalAlignment="Stretch">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="HorizontalAlignment" Value="Left" />
                                                <Setter Property="Background" Value="#EFE9FB" />
                                                <Setter Property="CornerRadius" Value="4,14,14,14" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsUser}" Value="True">
                                                        <Setter Property="HorizontalAlignment" Value="Right" />
                                                        <Setter Property="Background" Value="#E8E2D8" />
                                                        <Setter Property="CornerRadius" Value="14,4,14,14" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <StackPanel>
                                            <TextBlock FontSize="10"
                                                       FontWeight="SemiBold"
                                                       Foreground="#7A6BA8"
                                                       Text="{Binding SpeakerName}" />
                                            <RichTextBox Margin="0,4,0,0"
                                                         Padding="0"
                                                         FontFamily="Malgun Gothic"
                                                         FontSize="14"
                                                         Foreground="#202A35"
                                                         Background="Transparent"
                                                         BorderThickness="0"
                                                         IsReadOnly="True"
                                                         IsReadOnlyCaretVisible="False"
                                                         IsDocumentEnabled="True"
                                                         HorizontalScrollBarVisibility="Disabled"
                                                         VerticalScrollBarVisibility="Disabled"
                                                         behaviors:InlineMarkup.Text="{Binding DisplayText, Mode=OneWay}"
                                                         behaviors:InlineMarkup.Roleplay="{Binding IsRoleplay, Mode=OneWay}"
                                                         ToolTip="드래그해서 선택하거나 Ctrl+C로 복사할 수 있습니다.">
                                                <RichTextBox.ContextMenu>
                                                    <ContextMenu>
                                                        <MenuItem Command="ApplicationCommands.Copy" Header="복사" />
                                                        <MenuItem Command="ApplicationCommands.SelectAll" Header="전체 선택" />
                                                    </ContextMenu>
                                                </RichTextBox.ContextMenu>
                                            </RichTextBox>
                                            <TextBlock Margin="0,4,0,0"
                                                       HorizontalAlignment="Right"
                                                       FontFamily="Consolas"
                                                       FontSize="9"
                                                       Foreground="#9A90B5"
                                                       Text="{Binding Timestamp, StringFormat={}{0:HH:mm}}" />
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Border>

                <Grid Grid.Row="3" Margin="0,10,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBox x:Name="PromptTextBox"
                             MinHeight="60"
                             MaxHeight="120"
                             Padding="12,10"
                             AcceptsReturn="True"
                             TextWrapping="Wrap"
                             VerticalScrollBarVisibility="Auto"
                             BorderBrush="#B8AEDA"
                             BorderThickness="1"
                             PreviewKeyDown="PromptTextBox_OnPreviewKeyDown"
                             Text="{Binding InputText, UpdateSourceTrigger=PropertyChanged}"
                             ToolTip="평문=대사 · *행동* · (속마음)" />
                    <Button x:Name="SendButton"
                            Grid.Column="1"
                            Margin="8,0,0,0"
                            MinWidth="76"
                            Padding="14,8"
                            VerticalAlignment="Stretch"
                            Background="#9B6AD6"
                            Foreground="White"
                            BorderThickness="0"
                            Command="{Binding SendCommand}"
                            Content="SEND" />
                </Grid>
            </Grid>
        </Border>
    </Grid>
</Window>
