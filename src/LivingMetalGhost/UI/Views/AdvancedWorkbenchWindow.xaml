<Window x:Class="LivingMetalGhost.UI.Views.AdvancedWorkbenchWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Ghost Workbench"
        Width="980"
        Height="680"
        MinWidth="780"
        MinHeight="520"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        ShowActivated="False">
    <Grid Background="Transparent">
        <Border Margin="10"
                Padding="18"
                CornerRadius="24"
                Background="#F0F2F7"
                BorderThickness="2">
            <Border.BorderBrush>
                <SolidColorBrush x:Name="WorkbenchBorder" Color="#7B4FC8" />
            </Border.BorderBrush>
            <Border.Effect>
                <DropShadowEffect BlurRadius="26"
                                  ShadowDepth="8"
                                  Opacity="0.32"
                                  Color="#101820" />
            </Border.Effect>

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Grid MouseLeftButtonDown="Header_OnMouseLeftButtonDown"
                      Cursor="SizeAll">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel>
                        <TextBlock FontFamily="Bahnschrift"
                                   FontSize="24"
                                   FontWeight="SemiBold"
                                   Foreground="#18212D"
                                   Text="GHOST WORKBENCH" />
                        <TextBlock Margin="0,3,0,0"
                                   FontFamily="Consolas"
                                   FontSize="11"
                                   Foreground="#667085"
                                   Text="{Binding ActiveProviderLabel}" />
                    </StackPanel>
                    <StackPanel Grid.Column="1"
                                Orientation="Horizontal"
                                VerticalAlignment="Top">
                        <Button Margin="0,0,8,0"
                                Padding="12,7"
                                Background="#FFFFFF"
                                BorderBrush="#CBD0DC"
                                BorderThickness="1"
                                Foreground="#18212D"
                                Click="ExitAdvancedButton_OnClick"
                                Content="일반으로" />
                        <Button Width="32"
                                Height="32"
                                Padding="0"
                                Background="#18212D"
                                Foreground="White"
                                BorderThickness="0"
                                Click="CloseButton_OnClick"
                                Content="×" />
                    </StackPanel>
                </Grid>

                <Grid Grid.Row="1"
                      Margin="0,16,0,14">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2.2*" />
                        <ColumnDefinition Width="16" />
                        <ColumnDefinition Width="1*" />
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0"
                            Padding="10"
                            CornerRadius="18"
                            Background="#FFFDF8"
                            BorderBrush="#D7DAE3"
                            BorderThickness="1">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            <TextBlock FontFamily="Bahnschrift"
                                       FontSize="13"
                                       FontWeight="SemiBold"
                                       Foreground="#445066"
                                       Text="대화 / 분석" />
                            <ScrollViewer x:Name="ConversationScrollViewer"
                                          Grid.Row="1"
                                          Margin="0,8,0,0"
                                          VerticalScrollBarVisibility="Auto">
                                <ItemsControl ItemsSource="{Binding Messages}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border MaxWidth="560"
                                                    Margin="4,4"
                                                    Padding="12,9">
                                                <Border.Style>
                                                    <Style TargetType="Border">
                                                        <Setter Property="HorizontalAlignment" Value="Left" />
                                                        <Setter Property="Background" Value="#E8EEF8" />
                                                        <Setter Property="CornerRadius" Value="4,14,14,14" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsUser}" Value="True">
                                                                <Setter Property="HorizontalAlignment" Value="Right" />
                                                                <Setter Property="Background" Value="#E9E2F5" />
                                                                <Setter Property="CornerRadius" Value="14,4,14,14" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>
                                                <StackPanel>
                                                    <TextBlock FontSize="10"
                                                               FontWeight="SemiBold"
                                                               Foreground="#64707E"
                                                               Text="{Binding SpeakerName}" />
                                                    <TextBox Margin="0,4,0,0"
                                                             Padding="0"
                                                             FontFamily="Malgun Gothic"
                                                             FontSize="14"
                                                             Foreground="#202A35"
                                                             Background="Transparent"
                                                             BorderThickness="0"
                                                             IsReadOnly="True"
                                                             IsReadOnlyCaretVisible="False"
                                                             TextWrapping="Wrap"
                                                             AcceptsReturn="True"
                                                             Text="{Binding DisplayText, Mode=OneWay}">
                                                        <TextBox.ContextMenu>
                                                            <ContextMenu>
                                                                <MenuItem Command="ApplicationCommands.Copy" Header="복사" />
                                                                <MenuItem Command="ApplicationCommands.SelectAll" Header="전체 선택" />
                                                            </ContextMenu>
                                                        </TextBox.ContextMenu>
                                                    </TextBox>
                                                </StackPanel>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>
                        </Grid>
                    </Border>

                    <Grid Grid.Column="2">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="12" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <Border Padding="12"
                                CornerRadius="18"
                                Background="#FFFFFF"
                                BorderBrush="#D7DAE3"
                                BorderThickness="1">
                            <StackPanel>
                                <TextBlock FontFamily="Bahnschrift"
                                           FontSize="13"
                                           FontWeight="SemiBold"
                                           Foreground="#445066"
                                           Text="Context" />
                                <TextBlock Margin="0,8,0,0"
                                           FontFamily="Consolas"
                                           FontSize="11"
                                           Foreground="#667085"
                                           Text="{Binding ActiveProviderLabel}" />
                                <TextBlock x:Name="WorkbenchContextText"
                                           Margin="0,8,0,0"
                                           FontFamily="Consolas"
                                           FontSize="10"
                                           Foreground="#667085"
                                           TextWrapping="Wrap"
                                           Text="Workspace: default" />
                                <TextBlock Margin="0,8,0,0"
                                           FontSize="11"
                                           Foreground="#667085"
                                           Text="롤플레잉 장면 상태는 고급 모드에서 사용하지 않습니다." />
                                <WrapPanel Margin="0,10,0,0">
                                    <Button Margin="0,0,6,6"
                                            Padding="9,5"
                                            Background="#F8F9FC"
                                            BorderBrush="#CBD0DC"
                                            BorderThickness="1"
                                            Click="NewAdvancedSessionButton_OnClick"
                                            Content="새 세션" />
                                    <Button Margin="0,0,6,6"
                                            Padding="9,5"
                                            Background="#F8F9FC"
                                            BorderBrush="#CBD0DC"
                                            BorderThickness="1"
                                            Click="ProjectMemoryButton_OnClick"
                                            Content="기억 보기" />
                                    <Button Margin="0,0,6,6"
                                            Padding="9,5"
                                            Background="#7B4FC8"
                                            Foreground="White"
                                            BorderThickness="0"
                                            Click="PromoteMemoryButton_OnClick"
                                            Content="마지막 답변 기억" />
                                </WrapPanel>
                            </StackPanel>
                        </Border>

                        <Border Grid.Row="2"
                                Padding="12"
                                CornerRadius="18"
                                Background="#171E2C"
                                BorderBrush="#7B4FC8"
                                BorderThickness="1">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>
                                <StackPanel>
                                    <TextBlock FontFamily="Bahnschrift"
                                               FontSize="13"
                                               FontWeight="SemiBold"
                                               Foreground="#D9CBFF"
                                               Text="Agent Dock" />
                                    <TextBlock Margin="0,3,0,8"
                                               FontSize="10"
                                               Foreground="#8E9AAF"
                                               Text="작업 에이전트 상태. 마우스를 올리면 요약을 볼 수 있습니다." />
                                </StackPanel>
                                <ScrollViewer Grid.Row="1"
                                              VerticalScrollBarVisibility="Auto">
                                    <ItemsControl ItemsSource="{Binding ActiveAgentJobs}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Margin="0,0,0,8"
                                                        Padding="10,8"
                                                        CornerRadius="10"
                                                        Background="#232A3B"
                                                        BorderBrush="#4A5570"
                                                        BorderThickness="1"
                                                        ToolTip="{Binding TooltipText}">
                                                    <StackPanel>
                                                        <TextBlock FontFamily="Bahnschrift"
                                                                   FontSize="12"
                                                                   FontWeight="SemiBold"
                                                                   Foreground="#FFFFFF"
                                                                   Text="{Binding DisplayName}" />
                                                        <TextBlock Margin="0,2,0,0"
                                                                   FontSize="10"
                                                                   Foreground="#AAB3C5"
                                                                   Text="{Binding StatusLabel}" />
                                                        <TextBlock Margin="0,2,0,6"
                                                                   FontSize="10"
                                                                   Foreground="#7F8AA3"
                                                                   TextWrapping="Wrap"
                                                                   Text="{Binding Summary}" />
                                                        <ProgressBar Height="5"
                                                                     Minimum="0"
                                                                     Maximum="1"
                                                                     Value="{Binding Progress}" />
                                                    </StackPanel>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </ScrollViewer>
                            </Grid>
                        </Border>
                    </Grid>
                </Grid>

                <Grid Grid.Row="2">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBox x:Name="PromptTextBox"
                             MinHeight="72"
                             MaxHeight="150"
                             Padding="12,10"
                             AcceptsReturn="True"
                             TextWrapping="Wrap"
                             VerticalScrollBarVisibility="Auto"
                             BorderBrush="#A9A095"
                             BorderThickness="1"
                             PreviewKeyDown="PromptTextBox_OnPreviewKeyDown"
                             Text="{Binding InputText, UpdateSourceTrigger=PropertyChanged}" />
                    <Button Grid.Column="1"
                            Margin="10,0,0,0"
                            MinWidth="92"
                            Padding="16,8"
                            VerticalAlignment="Stretch"
                            Background="#7B4FC8"
                            Foreground="White"
                            BorderThickness="0"
                            Command="{Binding SendCommand}"
                            Content="RUN" />
                </Grid>
            </Grid>
        </Border>
    </Grid>
</Window>
