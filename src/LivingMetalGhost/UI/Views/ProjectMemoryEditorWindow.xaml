<Window x:Class="LivingMetalGhost.UI.Views.ProjectMemoryEditorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Project Memory Editor"
        Width="560"
        Height="500"
        MinWidth="480"
        MinHeight="420"
        WindowStartupLocation="CenterOwner"
        Background="#F0F2F7">
    <Border Margin="14"
            Padding="16"
            CornerRadius="18"
            Background="#FFFDF8"
            BorderBrush="#CBD0DC"
            BorderThickness="1">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <StackPanel>
                <TextBlock FontFamily="Bahnschrift"
                           FontSize="20"
                           FontWeight="SemiBold"
                           Foreground="#18212D"
                           Text="프로젝트 기억 저장" />
                <TextBlock x:Name="SourceSessionText"
                           Margin="0,4,0,0"
                           FontFamily="Consolas"
                           FontSize="11"
                           Foreground="#667085" />
            </StackPanel>

            <Grid Grid.Row="1"
                  Margin="0,16,0,10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <TextBlock VerticalAlignment="Center"
                           Margin="0,0,10,0"
                           FontWeight="SemiBold"
                           Foreground="#445066"
                           Text="Type" />
                <ComboBox x:Name="MemoryTypeComboBox"
                          Grid.Column="1"
                          MinHeight="32"
                          SelectedIndex="0">
                    <ComboBoxItem Content="decision" />
                    <ComboBoxItem Content="fact" />
                    <ComboBoxItem Content="warning" />
                    <ComboBoxItem Content="todo" />
                    <ComboBoxItem Content="preference" />
                </ComboBox>
            </Grid>

            <Grid Grid.Row="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                <TextBlock Margin="0,0,0,6"
                           FontWeight="SemiBold"
                           Foreground="#445066"
                           Text="Content" />
                <TextBox x:Name="MemoryContentTextBox"
                         Grid.Row="1"
                         Padding="10"
                         AcceptsReturn="True"
                         TextWrapping="Wrap"
                         VerticalScrollBarVisibility="Auto"
                         FontFamily="Malgun Gothic"
                         FontSize="13" />
            </Grid>

            <StackPanel Grid.Row="3"
                        Margin="0,14,0,0"
                        Orientation="Horizontal"
                        HorizontalAlignment="Right">
                <Button MinWidth="84"
                        Padding="14,7"
                        Margin="0,0,8,0"
                        Background="#FFFFFF"
                        BorderBrush="#CBD0DC"
                        BorderThickness="1"
                        Click="CancelButton_OnClick"
                        Content="취소" />
                <Button MinWidth="84"
                        Padding="14,7"
                        Background="#7B4FC8"
                        Foreground="White"
                        BorderThickness="0"
                        Click="SaveButton_OnClick"
                        Content="저장" />
            </StackPanel>
        </Grid>
    </Border>
</Window>
