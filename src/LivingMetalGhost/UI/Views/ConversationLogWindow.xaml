<Window x:Class="LivingMetalGhost.UI.Views.ConversationLogWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="대화 로그"
        Width="820"
        Height="620"
        MinWidth="680"
        MinHeight="480"
        WindowStartupLocation="CenterOwner"
        Background="#F4EFE5"
        Loaded="Window_OnLoaded">
    <Grid Margin="20">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="170" />
            <ColumnDefinition Width="16" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Border Padding="12"
                CornerRadius="14"
                Background="#18212D">
            <DockPanel>
                <TextBlock DockPanel.Dock="Top"
                           Margin="4,2,4,12"
                           FontFamily="Bahnschrift"
                           FontSize="17"
                           FontWeight="SemiBold"
                           Foreground="White"
                           Text="DAILY LOG" />
                <ListBox ItemsSource="{Binding Dates}"
                         SelectedItem="{Binding SelectedDate}"
                         SelectionChanged="DateList_OnSelectionChanged"
                         Background="Transparent"
                         BorderThickness="0"
                         Foreground="White">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Padding="7"
                                       FontFamily="Consolas"
                                       Text="{Binding StringFormat={}{0:yyyy-MM-dd}}" />
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </DockPanel>
        </Border>

        <Grid Grid.Column="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Grid Margin="0,0,0,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock FontFamily="Bahnschrift"
                           FontSize="24"
                           FontWeight="SemiBold"
                           Foreground="#18212D"
                           Text="{Binding SelectedDate, StringFormat={}{0:yyyy년 M월 d일}}" />
                <StackPanel Grid.Column="1"
                            Orientation="Horizontal"
                            VerticalAlignment="Bottom">
                    <TextBlock Margin="0,0,8,0"
                               VerticalAlignment="Center"
                               FontSize="12"
                               Foreground="#64707E"
                               Text="모드" />
                    <ComboBox Width="96"
                              Margin="0,0,14,0"
                              ItemsSource="{Binding ModeFilters}"
                              SelectedItem="{Binding SelectedModeFilter}" />
                    <TextBlock VerticalAlignment="Center"
                               Foreground="#64707E"
                               Text="{Binding StatusMessage}" />
                </StackPanel>
            </Grid>

            <ListBox Grid.Row="1"
                     ItemsSource="{Binding Entries}"
                     Background="Transparent"
                     BorderThickness="0"
                     ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Border Margin="0,0,0,12"
                                Padding="15"
                                CornerRadius="14"
                                Background="#FFFDF8"
                                BorderBrush="#D8D0C3"
                                BorderThickness="1">
                            <StackPanel>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Orientation="Horizontal">
                                        <Border Margin="0,0,8,0"
                                                Padding="6,1"
                                                CornerRadius="6"
                                                VerticalAlignment="Center"
                                                Background="#E1D7FF">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding ModeLabel}" Value="">
                                                            <Setter Property="Visibility" Value="Collapsed" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <TextBlock FontSize="10"
                                                       FontWeight="SemiBold"
                                                       Foreground="#3A2E6B"
                                                       Text="{Binding ModeLabel}" />
                                        </Border>
                                        <TextBlock FontFamily="Consolas"
                                                   FontSize="11"
                                                   VerticalAlignment="Center"
                                                   Foreground="#64707E"
                                                   Text="{Binding Provider}" />
                                    </StackPanel>
                                    <TextBlock Grid.Column="1"
                                               FontFamily="Consolas"
                                               FontSize="11"
                                               Foreground="#64707E"
                                               Text="{Binding Timestamp, StringFormat={}{0:HH:mm:ss}}" />
                                </Grid>
                                <Border Margin="0,10,40,0"
                                        Padding="11"
                                        CornerRadius="12,12,3,12"
                                        Background="#E8E2D8">
                                    <TextBlock TextWrapping="Wrap"
                                               Foreground="#27313C"
                                               Text="{Binding UserText}" />
                                </Border>
                                <Border Margin="40,8,0,0"
                                        Padding="11"
                                        CornerRadius="12,12,12,3"
                                        Background="#DDEFEA">
                                    <TextBlock TextWrapping="Wrap"
                                               Foreground="#18352F"
                                               Text="{Binding AssistantText}" />
                                </Border>
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </Grid>
    </Grid>
</Window>
