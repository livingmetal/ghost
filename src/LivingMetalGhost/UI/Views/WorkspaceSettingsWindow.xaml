<Window x:Class="LivingMetalGhost.UI.Views.WorkspaceSettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Workspace Settings"
        Width="720"
        Height="620"
        MinWidth="620"
        MinHeight="520"
        WindowStartupLocation="CenterOwner"
        Background="#F0F2F7">
    <Border Margin="14"
            Padding="16"
            CornerRadius="18"
            Background="#FFFDF8"
            BorderBrush="#CBD0DC"
            BorderThickness="1">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <StackPanel>
                <TextBlock FontFamily="Bahnschrift"
                           FontSize="22"
                           FontWeight="SemiBold"
                           Foreground="#18212D"
                           Text="Workspace Settings" />
                <TextBlock x:Name="SettingsFileText"
                           Margin="0,4,0,0"
                           FontFamily="Consolas"
                           FontSize="11"
                           Foreground="#667085" />
            </StackPanel>

            <ScrollViewer Grid.Row="1"
                          Margin="0,16,0,14"
                          VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <TextBlock FontWeight="SemiBold" Text="Workspace ID" />
                    <TextBox x:Name="WorkspaceIdTextBox"
                             Margin="0,5,0,12"
                             Padding="8" />

                    <TextBlock FontWeight="SemiBold" Text="Display Name" />
                    <TextBox x:Name="DisplayNameTextBox"
                             Margin="0,5,0,12"
                             Padding="8" />

                    <TextBlock FontWeight="SemiBold" Text="Root Path" />
                    <TextBox x:Name="RootPathTextBox"
                             Margin="0,5,0,12"
                             Padding="8"
                             FontFamily="Consolas" />

                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="12" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0">
                            <TextBlock FontWeight="SemiBold" Text="Allowed Read Paths" />
                            <TextBox x:Name="AllowedReadPathsTextBox"
                                     Margin="0,5,0,0"
                                     Padding="8"
                                     Height="110"
                                     AcceptsReturn="True"
                                     TextWrapping="NoWrap"
                                     VerticalScrollBarVisibility="Auto"
                                     HorizontalScrollBarVisibility="Auto"
                                     FontFamily="Consolas" />
                        </StackPanel>

                        <StackPanel Grid.Column="2">
                            <TextBlock FontWeight="SemiBold" Text="Allowed Write Paths" />
                            <TextBox x:Name="AllowedWritePathsTextBox"
                                     Margin="0,5,0,0"
                                     Padding="8"
                                     Height="110"
                                     AcceptsReturn="True"
                                     TextWrapping="NoWrap"
                                     VerticalScrollBarVisibility="Auto"
                                     HorizontalScrollBarVisibility="Auto"
                                     FontFamily="Consolas" />
                        </StackPanel>
                    </Grid>

                    <TextBlock FontWeight="SemiBold" Text="Allowed Commands" />
                    <TextBox x:Name="AllowedCommandsTextBox"
                             Margin="0,5,0,12"
                             Padding="8"
                             Height="100"
                             AcceptsReturn="True"
                             TextWrapping="NoWrap"
                             VerticalScrollBarVisibility="Auto"
                             HorizontalScrollBarVisibility="Auto"
                             FontFamily="Consolas" />

                    <StackPanel Orientation="Horizontal">
                        <CheckBox x:Name="RequireWriteApprovalCheckBox"
                                  Margin="0,0,18,0"
                                  Content="쓰기 승인 필요" />
                        <CheckBox x:Name="RequireExecuteApprovalCheckBox"
                                  Content="명령 실행 승인 필요" />
                    </StackPanel>

                    <TextBlock Margin="0,14,0,0"
                               Foreground="#667085"
                               TextWrapping="Wrap"
                               Text="한 줄에 하나씩 입력하세요. 현재는 고급모드 프롬프트/컨텍스트에 정책을 반영하는 단계이며, 실제 파일 쓰기와 명령 실행 차단은 다음 단계에서 연결합니다." />
                </StackPanel>
            </ScrollViewer>

            <StackPanel Grid.Row="2"
                        Orientation="Horizontal"
                        HorizontalAlignment="Right">
                <Button MinWidth="84"
                        Padding="14,7"
                        Margin="0,0,8,0"
                        Background="#FFFFFF"
                        BorderBrush="#CBD0DC"
                        BorderThickness="1"
                        Click="CancelButton_OnClick"
                        Content="취소" />
                <Button MinWidth="84"
                        Padding="14,7"
                        Background="#7B4FC8"
                        Foreground="White"
                        BorderThickness="0"
                        Click="SaveButton_OnClick"
                        Content="저장" />
            </StackPanel>
        </Grid>
    </Border>
</Window>
