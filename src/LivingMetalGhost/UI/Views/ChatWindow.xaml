<Window x:Class="LivingMetalGhost.UI.Views.ChatWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:behaviors="clr-namespace:LivingMetalGhost.UI.Behaviors"
        Title="LivingMetalGhost Chat"
        Width="430"
        Height="300"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        ShowActivated="False">
    <Grid Background="Transparent">
        <!-- ChatWindow.xaml.cs still updates these named elements when modes change.
             They stay hidden because the daily chat surface is now bubble-first, not console-first. -->
        <StackPanel Visibility="Collapsed">
            <TextBlock x:Name="TitleLabel" />
            <TextBlock x:Name="ProviderLabel" />
        </StackPanel>

        <Grid Margin="8">
            <Grid.RowDefinitions>
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Border x:Name="RootBorder"
                    Grid.Row="0"
                    MinHeight="122"
                    MaxHeight="168"
                    Margin="0,0,38,10"
                    Padding="18,16,18,16"
                    Background="#F8F3EC"
                    BorderThickness="2"
                    CornerRadius="22"
                    MouseLeftButtonDown="Header_OnMouseLeftButtonDown"
                    Cursor="SizeAll">
                <Border.BorderBrush>
                    <SolidColorBrush x:Name="BorderAccent" Color="#EFE7DC" />
                </Border.BorderBrush>
                <Border.Effect>
                    <DropShadowEffect BlurRadius="18"
                                      ShadowDepth="5"
                                      Opacity="0.22"
                                      Color="#221729" />
                </Border.Effect>
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock FontFamily="Bahnschrift"
                                   FontSize="13"
                                   FontWeight="SemiBold"
                                   Foreground="#8E65C8"
                                   Text="{Binding CharacterDisplayName}" />
                        <Button Grid.Column="1"
                                Width="22"
                                Height="22"
                                Padding="0"
                                Background="Transparent"
                                Foreground="#9D8D7F"
                                BorderThickness="0"
                                Click="CloseButton_OnClick"
                                Content="×"
                                ToolTip="대화창 닫기" />
                    </Grid>

                    <ScrollViewer x:Name="ConversationScrollViewer"
                                  Grid.Row="1"
                                  Margin="0,8,0,0"
                                  MaxHeight="108"
                                  VerticalScrollBarVisibility="Auto">
                        <ItemsControl ItemsSource="{Binding Messages}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Margin="0,0,0,10"
                                            Padding="0"
                                            Background="Transparent">
                                        <StackPanel>
                                            <TextBlock FontSize="10"
                                                       FontWeight="SemiBold"
                                                       Foreground="#9D75D2"
                                                       Text="{Binding SpeakerName}">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Visibility" Value="Visible" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsUser}" Value="True">
                                                                <Setter Property="Foreground" Value="#7C7168" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                            <RichTextBox Margin="0,4,0,0"
                                                         Padding="0"
                                                         FontFamily="Malgun Gothic"
                                                         FontSize="15"
                                                         Foreground="#241B2B"
                                                         Background="Transparent"
                                                         BorderThickness="0"
                                                         IsReadOnly="True"
                                                         IsReadOnlyCaretVisible="False"
                                                         IsDocumentEnabled="True"
                                                         HorizontalScrollBarVisibility="Disabled"
                                                         VerticalScrollBarVisibility="Disabled"
                                                         behaviors:InlineMarkup.Text="{Binding DisplayText, Mode=OneWay}"
                                                         behaviors:InlineMarkup.Roleplay="{Binding IsRoleplay, Mode=OneWay}"
                                                         ToolTip="드래그해서 선택하거나 Ctrl+C로 복사할 수 있습니다.">
                                                <RichTextBox.ContextMenu>
                                                    <ContextMenu>
                                                        <MenuItem Command="ApplicationCommands.Copy" Header="복사" />
                                                        <MenuItem Command="ApplicationCommands.SelectAll" Header="전체 선택" />
                                                    </ContextMenu>
                                                </RichTextBox.ContextMenu>
                                            </RichTextBox>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>
            </Border>

            <Polygon Grid.Row="0"
                     HorizontalAlignment="Right"
                     VerticalAlignment="Bottom"
                     Margin="0,0,48,0"
                     Points="0,0 34,18 8,34"
                     Fill="#F8F3EC"
                     Stroke="#EFE7DC"
                     StrokeThickness="2" />

            <Border Grid.Row="1"
                    Margin="34,0,0,0"
                    Padding="12,10"
                    Background="#F7EFE7"
                    BorderBrush="#E3D7CC"
                    BorderThickness="1"
                    CornerRadius="18">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="16"
                                      ShadowDepth="4"
                                      Opacity="0.20"
                                      Color="#221729" />
                </Border.Effect>
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Row="0"
                               Grid.RowSpan="2"
                               Margin="2,0,10,0"
                               VerticalAlignment="Center"
                               FontSize="22"
                               Foreground="#A579D8"
                               Text="✦" />

                    <TextBox x:Name="PromptTextBox"
                             Grid.Row="0"
                             Grid.Column="1"
                             MinHeight="44"
                             MaxHeight="84"
                             Padding="4,6"
                             AcceptsReturn="True"
                             TextWrapping="Wrap"
                             VerticalScrollBarVisibility="Auto"
                             Background="Transparent"
                             Foreground="#241B2B"
                             BorderThickness="0"
                             PreviewKeyDown="PromptTextBox_OnPreviewKeyDown"
                             Text="{Binding InputText, UpdateSourceTrigger=PropertyChanged}"
                             ToolTip="메시지를 입력하세요. Enter 전송, Shift+Enter 줄바꿈" />

                    <Button x:Name="SendButton"
                            Grid.Row="0"
                            Grid.Column="2"
                            Width="44"
                            Height="44"
                            Margin="10,0,0,0"
                            Padding="0"
                            VerticalAlignment="Center"
                            Background="#9B6AD6"
                            Foreground="White"
                            BorderThickness="0"
                            Command="{Binding SendCommand}"
                            Content="➤"
                            FontSize="20"
                            ToolTip="보내기" />

                    <StackPanel Grid.Row="1"
                                Grid.Column="1"
                                Grid.ColumnSpan="2"
                                Margin="0,8,0,0"
                                Orientation="Horizontal">
                        <Button Padding="10,5"
                                Margin="0,0,6,0"
                                Background="#EFE5DA"
                                BorderBrush="#DACEC2"
                                BorderThickness="1"
                                Foreground="#6E6258"
                                Command="{Binding SendCommand}"
                                Content="이야기 이어가기"
                                ToolTip="입력한 문장으로 대화를 이어갑니다." />
                        <Button Padding="10,5"
                                Margin="0,0,6,0"
                                Background="#EFE5DA"
                                BorderBrush="#DACEC2"
                                BorderThickness="1"
                                Foreground="#6E6258"
                                Command="{Binding OpenSettingsCommand}"
                                Content="설정" />
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>
