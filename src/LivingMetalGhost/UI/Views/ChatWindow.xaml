<Window x:Class="LivingMetalGhost.UI.Views.ChatWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="LivingMetalGhost Chat"
        Width="456"
        Height="292"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        ShowActivated="False">
    <Window.Resources>
        <LinearGradientBrush x:Key="BubbleFillBrush" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#FFFFFC" Offset="0" />
            <GradientStop Color="#FBF5EF" Offset="0.58" />
            <GradientStop Color="#F1E7DD" Offset="1" />
        </LinearGradientBrush>

        <LinearGradientBrush x:Key="InputFillBrush" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#FFF8F0" Offset="0" />
            <GradientStop Color="#F6EADD" Offset="1" />
        </LinearGradientBrush>

        <Style x:Key="QuickActionButtonStyle" TargetType="Button">
            <Setter Property="Padding" Value="10,5" />
            <Setter Property="Margin" Value="0,0,6,0" />
            <Setter Property="Background" Value="#F0E7DD" />
            <Setter Property="BorderBrush" Value="#DDCFC2" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Foreground" Value="#6B5D52" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Cursor" Value="Hand" />
        </Style>
    </Window.Resources>

    <Grid Background="Transparent">
        <!-- ChatWindow.xaml.cs keeps these names for mode labels, but the default chat uses bubble UI. -->
        <StackPanel Visibility="Collapsed">
            <TextBlock x:Name="TitleLabel" />
            <TextBlock x:Name="ProviderLabel" />
        </StackPanel>

        <Grid Margin="8">
            <Grid.RowDefinitions>
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Grid x:Name="BubbleHost"
                  Grid.Row="0"
                  Margin="0,0,42,12"
                  Visibility="Collapsed"
                  Opacity="0"
                  IsHitTestVisible="False">
                <Grid.Effect>
                    <DropShadowEffect BlurRadius="26"
                                      ShadowDepth="7"
                                      Direction="300"
                                      Opacity="0.24"
                                      Color="#2A1A30" />
                </Grid.Effect>

                <!-- Soft outer glow. -->
                <Border Margin="2,4,4,8"
                        CornerRadius="30"
                        Background="#44FFFFFF" />

                <!-- Tail shadow, then tail fill. Keeping these separate makes the tail feel attached instead of pasted on. -->
                <Path HorizontalAlignment="Right"
                      VerticalAlignment="Bottom"
                      Margin="0,0,34,-14"
                      Fill="#1F2A1A30"
                      Data="M 3,0 C 14,6 28,13 40,30 C 25,22 12,22 3,0 Z" />
                <Path HorizontalAlignment="Right"
                      VerticalAlignment="Bottom"
                      Margin="0,0,36,-11"
                      Fill="#F1E7DD"
                      Stroke="#E8DDD2"
                      StrokeThickness="1"
                      Data="M 0,0 C 12,5 25,12 36,27 C 23,20 10,20 0,0 Z" />

                <Border x:Name="RootBorder"
                        Margin="0,0,0,6"
                        Padding="20,17,20,18"
                        CornerRadius="28"
                        BorderThickness="1.2"
                        Background="{StaticResource BubbleFillBrush}"
                        MouseLeftButtonDown="Header_OnMouseLeftButtonDown"
                        Cursor="SizeAll">
                    <Border.BorderBrush>
                        <SolidColorBrush x:Name="BorderAccent" Color="#E8DDD2" />
                    </Border.BorderBrush>
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <Border Width="28"
                                    Height="28"
                                    Margin="0,0,9,0"
                                    CornerRadius="14"
                                    Background="#F1E8FF"
                                    BorderBrush="#DFCFF9"
                                    BorderThickness="1">
                                <TextBlock HorizontalAlignment="Center"
                                           VerticalAlignment="Center"
                                           FontSize="14"
                                           Foreground="#9B6AD6"
                                           Text="✦" />
                            </Border>

                            <StackPanel Grid.Column="1"
                                        VerticalAlignment="Center">
                                <TextBlock FontFamily="Bahnschrift"
                                           FontSize="13"
                                           FontWeight="SemiBold"
                                           Foreground="#7C55BA"
                                           Text="{Binding CharacterDisplayName}" />
                                <TextBlock Margin="0,1,0,0"
                                           FontSize="10"
                                           Foreground="#9A8D82"
                                           Text="speaking" />
                            </StackPanel>

                            <TextBlock Grid.Column="2"
                                       VerticalAlignment="Top"
                                       FontSize="19"
                                       Foreground="#B184D8"
                                       Text="♥" />
                        </Grid>

                        <TextBlock Grid.Row="1"
                                   Margin="0,11,0,0"
                                   MaxHeight="98"
                                   FontFamily="Malgun Gothic"
                                   FontSize="15"
                                   FontWeight="SemiBold"
                                   LineHeight="23"
                                   TextWrapping="Wrap"
                                   TextTrimming="CharacterEllipsis"
                                   Foreground="#241B2B"
                                   Text="{Binding BubbleText}" />
                    </Grid>
                </Border>
            </Grid>

            <Border Grid.Row="1"
                    Margin="34,0,0,0"
                    Padding="12,10"
                    Background="{StaticResource InputFillBrush}"
                    BorderBrush="#E4D4C6"
                    BorderThickness="1"
                    CornerRadius="22">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="20"
                                      ShadowDepth="4"
                                      Direction="300"
                                      Opacity="0.18"
                                      Color="#24182B" />
                </Border.Effect>
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <Border Grid.Row="0"
                            Grid.RowSpan="2"
                            Width="34"
                            Height="34"
                            Margin="0,0,10,0"
                            VerticalAlignment="Center"
                            CornerRadius="17"
                            Background="#F2E8FF">
                        <TextBlock HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   FontSize="19"
                                   Foreground="#A579D8"
                                   Text="✦" />
                    </Border>

                    <TextBox x:Name="PromptTextBox"
                             Grid.Row="0"
                             Grid.Column="1"
                             MinHeight="42"
                             MaxHeight="80"
                             Padding="4,6"
                             AcceptsReturn="True"
                             TextWrapping="Wrap"
                             VerticalScrollBarVisibility="Auto"
                             Background="Transparent"
                             Foreground="#241B2B"
                             BorderThickness="0"
                             PreviewKeyDown="PromptTextBox_OnPreviewKeyDown"
                             Text="{Binding InputText, UpdateSourceTrigger=PropertyChanged}"
                             ToolTip="메시지를 입력하세요. Enter 전송, Shift+Enter 줄바꿈" />

                    <Button x:Name="SendButton"
                            Grid.Row="0"
                            Grid.Column="2"
                            Width="46"
                            Height="46"
                            Margin="10,0,0,0"
                            Padding="0"
                            VerticalAlignment="Center"
                            Background="#9B6AD6"
                            Foreground="White"
                            BorderThickness="0"
                            Command="{Binding SendCommand}"
                            Content="➤"
                            FontSize="20"
                            Cursor="Hand"
                            ToolTip="보내기" />

                    <StackPanel Grid.Row="1"
                                Grid.Column="1"
                                Grid.ColumnSpan="2"
                                Margin="0,8,0,0"
                                Orientation="Horizontal">
                        <Button Style="{StaticResource QuickActionButtonStyle}"
                                Command="{Binding OpenSettingsCommand}"
                                Content="설정" />
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>
