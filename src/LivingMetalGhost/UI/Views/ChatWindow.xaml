<Window x:Class="LivingMetalGhost.UI.Views.ChatWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="LivingMetalGhost Chat"
        Width="456"
        Height="254"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        ShowActivated="False">
    <Window.Resources>
        <LinearGradientBrush x:Key="BubbleFillBrush" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#FFFFFC" Offset="0" />
            <GradientStop Color="#FBF5EF" Offset="0.58" />
            <GradientStop Color="#F1E7DD" Offset="1" />
        </LinearGradientBrush>

        <LinearGradientBrush x:Key="InputFillBrush" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#FFF8F0" Offset="0" />
            <GradientStop Color="#F6EADD" Offset="1" />
        </LinearGradientBrush>
    </Window.Resources>

    <Grid Background="Transparent">
        <!-- ChatWindow.xaml.cs keeps these names for mode labels, but the default chat uses bubble UI. -->
        <StackPanel Visibility="Collapsed">
            <TextBlock x:Name="TitleLabel" />
            <TextBlock x:Name="ProviderLabel" />
        </StackPanel>

        <Grid Margin="8">
            <Grid.RowDefinitions>
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Grid x:Name="BubbleHost"
                  Grid.Row="0"
                  Margin="0,0,42,12"
                  Visibility="Collapsed"
                  Opacity="0"
                  IsHitTestVisible="False">
                <Grid.Effect>
                    <DropShadowEffect BlurRadius="26"
                                      ShadowDepth="7"
                                      Direction="300"
                                      Opacity="0.24"
                                      Color="#2A1A30" />
                </Grid.Effect>

                <Border Margin="2,4,4,8"
                        CornerRadius="30"
                        Background="#44FFFFFF" />

                <Path HorizontalAlignment="Right"
                      VerticalAlignment="Bottom"
                      Margin="0,0,34,-14"
                      Fill="#1F2A1A30"
                      Data="M 3,0 C 14,6 28,13 40,30 C 25,22 12,22 3,0 Z" />
                <Path HorizontalAlignment="Right"
                      VerticalAlignment="Bottom"
                      Margin="0,0,36,-11"
                      Fill="#F1E7DD"
                      Stroke="#E8DDD2"
                      StrokeThickness="1"
                      Data="M 0,0 C 12,5 25,12 36,27 C 23,20 10,20 0,0 Z" />

                <Border x:Name="RootBorder"
                        Margin="0,0,0,6"
                        Padding="20,17,20,18"
                        CornerRadius="28"
                        BorderThickness="1.2"
                        Background="{StaticResource BubbleFillBrush}"
                        MouseLeftButtonDown="Header_OnMouseLeftButtonDown"
                        Cursor="SizeAll">
                    <Border.BorderBrush>
                        <SolidColorBrush x:Name="BorderAccent" Color="#E8DDD2" />
                    </Border.BorderBrush>
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <StackPanel>
                            <TextBlock FontFamily="Bahnschrift"
                                       FontSize="13"
                                       FontWeight="SemiBold"
                                       Foreground="#7C55BA"
                                       Text="{Binding CharacterDisplayName}" />
                            <TextBlock Margin="0,1,0,0"
                                       FontSize="10"
                                       Foreground="#9A8D82"
                                       Text="speaking" />
                        </StackPanel>

                        <TextBlock x:Name="BubbleTextBlock"
                                   Grid.Row="1"
                                   Margin="0,11,0,0"
                                   MaxHeight="98"
                                   FontFamily="Malgun Gothic"
                                   FontSize="15"
                                   FontWeight="SemiBold"
                                   LineHeight="23"
                                   TextWrapping="Wrap"
                                   TextTrimming="CharacterEllipsis"
                                   Foreground="#241B2B" />
                    </Grid>
                </Border>
            </Grid>

            <Border x:Name="InputPanel"
                    Grid.Row="1"
                    Margin="34,0,0,0"
                    Padding="14,10"
                    Background="{StaticResource InputFillBrush}"
                    BorderBrush="#E4D4C6"
                    BorderThickness="1"
                    CornerRadius="22"
                    MouseLeftButtonDown="InputPanel_OnMouseLeftButtonDown">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="20"
                                      ShadowDepth="4"
                                      Direction="300"
                                      Opacity="0.18"
                                      Color="#24182B" />
                </Border.Effect>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <TextBox x:Name="PromptTextBox"
                             Grid.Column="0"
                             MinHeight="42"
                             MaxHeight="80"
                             Padding="4,6"
                             AcceptsReturn="True"
                             TextWrapping="Wrap"
                             VerticalScrollBarVisibility="Auto"
                             Background="Transparent"
                             Foreground="#241B2B"
                             BorderThickness="0"
                             PreviewMouseLeftButtonDown="InputPanel_OnMouseLeftButtonDown"
                             PreviewKeyDown="PromptTextBox_OnPreviewKeyDown"
                             Text="{Binding InputText, UpdateSourceTrigger=PropertyChanged}"
                             ToolTip="메시지를 입력하세요. Enter 전송, Shift+Enter 줄바꿈" />

                    <Button x:Name="SendButton"
                            Grid.Column="1"
                            Width="46"
                            Height="46"
                            Margin="10,0,0,0"
                            Padding="0"
                            VerticalAlignment="Center"
                            Background="#9B6AD6"
                            Foreground="White"
                            BorderThickness="0"
                            Command="{Binding SendCommand}"
                            Content="➤"
                            FontSize="20"
                            Cursor="Hand"
                            ToolTip="보내기" />
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>
