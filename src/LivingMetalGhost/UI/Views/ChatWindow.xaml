<Window x:Class="LivingMetalGhost.UI.Views.ChatWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="LivingMetalGhost Chat"
        Width="440"
        Height="276"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        ShowActivated="False">
    <Window.Resources>
        <Style x:Key="QuickActionButtonStyle" TargetType="Button">
            <Setter Property="Padding" Value="10,5" />
            <Setter Property="Margin" Value="0,0,6,0" />
            <Setter Property="Background" Value="#F0E7DD" />
            <Setter Property="BorderBrush" Value="#DDCFC2" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Foreground" Value="#6B5D52" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Cursor" Value="Hand" />
        </Style>
    </Window.Resources>

    <Grid Background="Transparent">
        <!-- ChatWindow.xaml.cs keeps these names for mode labels, but the default chat uses bubble UI. -->
        <StackPanel Visibility="Collapsed">
            <TextBlock x:Name="TitleLabel" />
            <TextBlock x:Name="ProviderLabel" />
        </StackPanel>

        <Grid Margin="8">
            <Grid.RowDefinitions>
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Grid x:Name="BubbleHost"
                  Grid.Row="0"
                  Margin="0,0,42,10"
                  Visibility="Collapsed"
                  Opacity="0"
                  IsHitTestVisible="False">
                <Border x:Name="RootBorder"
                        Padding="20,17,20,18"
                        CornerRadius="26"
                        BorderThickness="1.5"
                        MouseLeftButtonDown="Header_OnMouseLeftButtonDown"
                        Cursor="SizeAll">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="#FFFDF9" Offset="0" />
                            <GradientStop Color="#F6EFE8" Offset="1" />
                        </LinearGradientBrush>
                    </Border.Background>
                    <Border.BorderBrush>
                        <SolidColorBrush x:Name="BorderAccent" Color="#EEE3D8" />
                    </Border.BorderBrush>
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="24"
                                          ShadowDepth="5"
                                          Opacity="0.23"
                                          Color="#2A1A30" />
                    </Border.Effect>
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock FontFamily="Bahnschrift"
                                       FontSize="13"
                                       FontWeight="SemiBold"
                                       Foreground="#8B63C7"
                                       Text="{Binding CharacterDisplayName}" />
                            <TextBlock Grid.Column="1"
                                       FontSize="18"
                                       Foreground="#B184D8"
                                       Text="♥" />
                        </Grid>
                        <TextBlock Grid.Row="1"
                                   Margin="0,8,0,0"
                                   MaxHeight="104"
                                   FontFamily="Malgun Gothic"
                                   FontSize="15"
                                   LineHeight="22"
                                   TextWrapping="Wrap"
                                   TextTrimming="CharacterEllipsis"
                                   Foreground="#241B2B"
                                   Text="{Binding BubbleText}" />
                    </Grid>
                </Border>

                <Path HorizontalAlignment="Right"
                      VerticalAlignment="Bottom"
                      Margin="0,0,30,-13"
                      Fill="#F6EFE8"
                      Stroke="#EEE3D8"
                      StrokeThickness="1.5"
                      Data="M 0,0 C 13,3 26,11 36,26 C 24,19 10,20 0,0 Z" />
            </Grid>

            <Border Grid.Row="1"
                    Margin="34,0,0,0"
                    Padding="12,10"
                    Background="#F8EFE7"
                    BorderBrush="#E3D5C8"
                    BorderThickness="1"
                    CornerRadius="20">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="18"
                                      ShadowDepth="4"
                                      Opacity="0.20"
                                      Color="#24182B" />
                </Border.Effect>
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Row="0"
                               Grid.RowSpan="2"
                               Margin="2,0,10,0"
                               VerticalAlignment="Center"
                               FontSize="22"
                               Foreground="#A579D8"
                               Text="✦" />

                    <TextBox x:Name="PromptTextBox"
                             Grid.Row="0"
                             Grid.Column="1"
                             MinHeight="42"
                             MaxHeight="80"
                             Padding="4,6"
                             AcceptsReturn="True"
                             TextWrapping="Wrap"
                             VerticalScrollBarVisibility="Auto"
                             Background="Transparent"
                             Foreground="#241B2B"
                             BorderThickness="0"
                             PreviewKeyDown="PromptTextBox_OnPreviewKeyDown"
                             Text="{Binding InputText, UpdateSourceTrigger=PropertyChanged}"
                             ToolTip="메시지를 입력하세요. Enter 전송, Shift+Enter 줄바꿈" />

                    <Button x:Name="SendButton"
                            Grid.Row="0"
                            Grid.Column="2"
                            Width="46"
                            Height="46"
                            Margin="10,0,0,0"
                            Padding="0"
                            VerticalAlignment="Center"
                            Background="#9B6AD6"
                            Foreground="White"
                            BorderThickness="0"
                            Command="{Binding SendCommand}"
                            Content="➤"
                            FontSize="20"
                            Cursor="Hand"
                            ToolTip="보내기" />

                    <StackPanel Grid.Row="1"
                                Grid.Column="1"
                                Grid.ColumnSpan="2"
                                Margin="0,8,0,0"
                                Orientation="Horizontal">
                        <Button Style="{StaticResource QuickActionButtonStyle}"
                                Command="{Binding OpenSettingsCommand}"
                                Content="설정" />
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>
