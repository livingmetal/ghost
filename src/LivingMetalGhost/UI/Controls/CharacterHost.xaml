<UserControl x:Class="LivingMetalGhost.UI.Controls.CharacterHost"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:LivingMetalGhost.UI.Controls"
             Width="300"
             Height="380"
             Background="Transparent">
    <Grid>
        <controls:CodexTanCharacter x:Name="CodexTan"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Bottom"
                                    Mood="{Binding Mood, RelativeSource={RelativeSource AncestorType=controls:CharacterHost}}" />

        <Grid x:Name="SpriteCharacter"
              Visibility="Collapsed"
              ClipToBounds="True">
            <Grid x:Name="CharacterFrame"
                  HorizontalAlignment="Center"
                  VerticalAlignment="Top"
                  RenderTransformOrigin="0.5,0.0">
                <Grid.RenderTransform>
                    <TransformGroup>
                        <ScaleTransform x:Name="CharacterScale"
                                        ScaleX="1"
                                        ScaleY="1" />
                        <TranslateTransform x:Name="CharacterPresentationTranslate" />
                        <TranslateTransform x:Name="CharacterMotionTranslate" />
                    </TransformGroup>
                </Grid.RenderTransform>
                <Grid x:Name="ModularLayerHost"
                      Visibility="Collapsed" />
                <Image x:Name="SpriteBaseLayer"
                       Stretch="Uniform"
                       VerticalAlignment="Bottom" />
                <Image x:Name="SpritePoseLayer"
                       Stretch="Uniform"
                       VerticalAlignment="Bottom"
                       Visibility="Collapsed" />
            </Grid>
        </Grid>
    </Grid>
</UserControl>
